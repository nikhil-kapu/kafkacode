# KafkaCode configuration — all optional.
#
# Pattern-based scanning runs fully offline and needs no configuration.
#
# AI-powered analysis is opt-in (bring-your-own-key). Provide an API key to
# enable it; KafkaCode calls an OpenAI-compatible chat API directly.
# Get a free Groq key at https://console.groq.com/keys
# KAFKACODE_API_KEY=your_api_key_here

# Optional overrides (defaults shown):
# KAFKACODE_API_URL=https://api.groq.com/openai/v1
# KAFKACODE_MODEL=llama-3.1-8b-instant

# Advanced: use a self-hosted backend (POST /api/analyze) instead of calling the
# provider directly. If set, this takes precedence over KAFKACODE_API_KEY.
# KAFKACODE_BACKEND_ENDPOINT=https://your-backend.example.com
